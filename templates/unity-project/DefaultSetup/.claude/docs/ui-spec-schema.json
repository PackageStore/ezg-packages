{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ezg/unity-ui-spec-v1",
  "title": "Unity UI Spec v1",
  "type": "object",
  "required": [
    "specVersion",
    "screen",
    "feature",
    "branch",
    "designResolution",
    "contentRoot",
    "containers",
    "elements",
    "assumptions",
    "questions"
  ],
  "properties": {
    "specVersion": {"const": 1},
    "screen": {"type": "string", "minLength": 1},
    "feature": {"type": "string", "minLength": 1},
    "branch": {"enum": ["Popup", "FullScreen"]},
    "designResolution": {"const": [1080, 2400]},
    "contentRoot": {"type": "string", "minLength": 1},
    "containers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "children"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "type": {"enum": ["row", "col", "grid", "absolute"]},
          "parent": {"type": "string"},
          "children": {"type": "array", "items": {"type": "string"}},
          "size": {"$ref": "#/$defs/vec2"},
          "pos": {"$ref": "#/$defs/vec2"},
          "offsets": {"$ref": "#/$defs/padding"},
          "anchor": {"$ref": "#/$defs/anchor"},
          "position": {"enum": ["flow", "abs"]},
          "gap": {"type": "number", "minimum": 0},
          "padding": {"$ref": "#/$defs/padding"},
          "cellSize": {"$ref": "#/$defs/vec2"},
          "spacing": {"$ref": "#/$defs/vec2"},
          "columns": {"type": "integer", "minimum": 1},
          "childAlignment": {"$ref": "#/$defs/alignment"},
          "style": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "template", "parent"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "template": {"type": "string", "minLength": 1},
          "parent": {"type": "string", "minLength": 1},
          "size": {"$ref": "#/$defs/vec2"},
          "pos": {"$ref": "#/$defs/vec2"},
          "offsets": {"$ref": "#/$defs/padding"},
          "anchor": {"$ref": "#/$defs/anchor"},
          "position": {"enum": ["flow", "abs"]},
          "fontSize": {"type": "number", "exclusiveMinimum": 0},
          "color": {},
          "text": {"type": "string"},
          "localize": {
            "anyOf": [
              {"enum": ["dynamic", "none"]},
              {"type": "string", "pattern": "^#.+"}
            ]
          },
          "baseChrome": {"type": "boolean"},
          "style": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "mockupLane": {"enum": ["kit-composition", "custom"]},
    "questions": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "properties": {
              "q": {"type": "string"},
              "options": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {"type": "string"},
                    {
                      "type": "object",
                      "required": ["label", "patch"],
                      "properties": {
                        "label": {"type": "string", "minLength": 1},
                        "patch": {
                          "type": "array",
                          "maxItems": 100,
                          "items": {
                            "type": "object",
                            "required": ["op", "path"],
                            "properties": {
                              "op": {"enum": ["add", "remove", "replace"]},
                              "path": {"type": "string", "pattern": "^/(containers|elements|wiring|assumptions)(/|$)"},
                              "value": {}
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            },
            "required": ["q"]
          }
        ]
      }
    },
    "wiring": {"type": "object"}
  },
  "$defs": {
    "vec2": {
      "type": "array",
      "prefixItems": [{"type": "number"}, {"type": "number"}],
      "minItems": 2,
      "maxItems": 2
    },
    "padding": {
      "type": "array",
      "prefixItems": [
        {"type": "number"},
        {"type": "number"},
        {"type": "number"},
        {"type": "number"}
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "anchor": {
      "enum": [
        "top-left", "top-center", "top-right",
        "middle-left", "center", "middle-right",
        "bottom-left", "bottom-center", "bottom-right",
        "stretch"
      ]
    },
    "alignment": {
      "enum": [
        "top-left", "top-center", "top-right",
        "middle-left", "center", "middle-right",
        "bottom-left", "bottom-center", "bottom-right"
      ]
    }
  },
  "additionalProperties": true
}
